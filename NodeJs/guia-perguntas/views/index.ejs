<!DOCTYPE html>
<html lang="pt-BR">
<%- include('partials/header.ejs') %>
<body>
  <%- include('partials/navbar.ejs') %>
  <div class="container">
    <hr>
    <h1>Perguntas </h1>
    <hr>
    <% questions.forEach((question)=>{ %>
      <br>
      <div class="card">
        <div class="card-body">
          <h3><%= question.title %></h3>
          
        </div>
        <div class="card-footer">
          <a href="/question/<%= question.id %>"><button class="btn btn-success">Responder</button></a>
        </div>
      </div>
     
      <p><%= question.description %></p>
    <% }) %>
  </div>
  <%- include('partials/footer.ejs') %>
</body>
</html>